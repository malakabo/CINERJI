<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#0A0A0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#12121A"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="CINERJI"
                android:textColor="#E50914"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"/>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="⏻ Quitter"
                android:textColor="#FFF"
                android:textSize="11sp"
                android:background="@drawable/btn_logout"
                android:layout_marginEnd="8dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"/>


            <Button
                android:id="@+id/buttonMic"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="🎤"
                android:textSize="16sp"
                android:background="@drawable/btn_circle_dark"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnScan"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="📷"
                android:textSize="16sp"
                android:background="@drawable/btn_circle_dark"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <EditText
                android:id="@+id/editTextSearch"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="38dp"
                android:hint="Rechercher un film..."
                android:textColorHint="#555566"
                android:textColor="#EEEEF5"
                android:textSize="13sp"
                android:background="@drawable/input_modern_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="text"
                android:singleLine="true"/>

            <Button
                android:id="@+id/buttonSearch"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:text="→"
                android:textSize="16sp"
                android:textColor="#FFF"
                android:background="@drawable/btn_red"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btnPopular"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="🔥 Populaire"
                    android:textColor="#FFF"
                    android:textSize="11sp"
                    android:background="@drawable/btn_category_active"
                    android:layout_marginEnd="8dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>

                <Button
                    android:id="@+id/btnTrending"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="📈 Tendance"
                    android:textColor="#888899"
                    android:textSize="11sp"
                    android:background="@drawable/btn_category_inactive"
                    android:layout_marginEnd="8dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>

                <Button
                    android:id="@+id/btnTopRated"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="⭐ Top noté"
                    android:textColor="#888899"
                    android:textSize="11sp"
                    android:background="@drawable/btn_category_inactive"
                    android:layout_marginEnd="8dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>

                <Button
                    android:id="@+id/btnChat"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="🤖 IA Chat"
                    android:textColor="#888899"
                    android:textSize="11sp"
                    android:background="@drawable/btn_category_inactive"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#12121A"
        android:elevation="8dp">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="◀ Précédent"
            android:textColor="#CCCCDD"
            android:textSize="12sp"
            android:background="@drawable/btn_pagination"
            android:layout_marginEnd="16dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"/>

        <TextView
            android:id="@+id/textPage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Page 1"
            android:textColor="#E50914"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginEnd="16dp"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Suivant ▶"
            android:textColor="#CCCCDD"
            android:textSize="12sp"
            android:background="@drawable/btn_pagination"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"/>
    </LinearLayout>
</LinearLayout>