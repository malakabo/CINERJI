<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#0A0A0F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#12121A"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="← Retour"
            android:textColor="#CCCCDD"
            android:textSize="12sp"
            android:background="@drawable/btn_pagination"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="🤖 Assistant IA"
            android:textColor="#F0F0FF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnCamera"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="📷"
            android:textSize="16sp"
            android:textColor="#FFF"
            android:background="@drawable/btn_circle_red"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#12121A"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <EditText
            android:id="@+id/editMessage"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="44dp"
            android:hint="Demande une recommandation..."
            android:textColorHint="#555566"
            android:textColor="#EEEEF5"
            android:textSize="13sp"
            android:background="@drawable/input_modern_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="text"
            android:singleLine="true"/>

        <Button
            android:id="@+id/btnSend"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="→"
            android:textSize="18sp"
            android:textColor="#FFF"
            android:background="@drawable/btn_red"
            android:layout_marginStart="10dp"/>
    </LinearLayout>
</LinearLayout>