<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card Poster + Titre + Description -->
            <androidx.cardview.widget.CardView
                app:cardElevation="12dp"
                app:cardCornerRadius="14dp"
                android:layout_margin="5dp"
                app:cardBackgroundColor="#16213e"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:gravity="center">

                    <!-- Poster -->
                    <androidx.cardview.widget.CardView
                        app:cardCornerRadius="10dp"
                        app:cardElevation="8dp"
                        app:cardBackgroundColor="#0f3460"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:id="@+id/imageview"
                            android:layout_width="180dp"
                            android:layout_height="260dp"
                            android:scaleType="centerCrop"/>

                    </androidx.cardview.widget.CardView>

                    <!-- Titre du film -->
                    <TextView
                        android:id="@+id/textName"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:layout_margin="7dp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <!-- Séparateur -->
                    <View
                        android:layout_width="60dp"
                        android:layout_height="2dp"
                        android:background="#7B8CDE"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="10dp"/>

                    <!-- Description -->
                    <TextView
                        android:id="@+id/Details"
                        android:layout_margin="5dp"
                        android:textColor="#B0BEC5"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bouton Play Trailer -->
            <Button
                android:id="@+id/playButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="▶  Regarder le Trailer"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#7B8CDE"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="4dp"/>

            <!-- Titre section carte -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎬  Cinémas à proximité"
                android:textColor="#7B8CDE"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"
                android:paddingStart="4dp"/>

            <!-- Carte Google Maps -->
            <androidx.cardview.widget.CardView
                app:cardCornerRadius="14dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#16213e"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <fragment
                    android:id="@+id/map"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="400dp"/>

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>